{
  "compilerOptions": {
    "target": "es2016",
    "module": "commonjs",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "incremental": true,
    "rootDir": ".",
    "outDir": "./dist",
    "tsBuildInfoFile": "./.tsbuildinfo",
    "jsx": "react",
    "allowJs": true
  },
  "include": ["**/*.ts", "**/**/*.ts", "**/*.tsx", "**/**/*.tsx", "**/*.d.ts", "**/**/*.d.ts"],
  "exclude": ["node_modules", "dist", "build", "out"]
}
