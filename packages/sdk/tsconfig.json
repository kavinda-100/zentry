{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "forceConsistentCasingInFileNames": true,
    "incremental": true,
    "rootDir": ".",
    "outDir": "./dist",
    "tsBuildInfoFile": "./.tsbuildinfo",
    "ignoreDeprecations": "6.0",
    "jsx": "react-jsx"
  },
  "include": ["**/*.ts", "**/**/*.ts", "**/*.tsx", "**/**/*.tsx", "**/*.d.ts", "**/**/*.d.ts"],
  "exclude": ["node_modules", "dist", "build", "out"]
}
