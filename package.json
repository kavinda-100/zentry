{
  "name": "zentry",
  "description": "Zentry is a production-grade, high-performance, multi-tenant Identity Provider (IdP) built as an educational blueprint for secure, \nhigh-throughput session topologies.",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --parallel --filter \"./apps/*\" dev",
    "start": "pnpm --parallel --filter \"./apps/*\" start",
    "build": "pnpm --filter \"./packages/*\" build && pnpm --filter \"./apps/*\" build",
    "db:generate": "pnpm --filter @zentry/database db:generate",
    "db:push": "pnpm --filter @zentry/database db:push",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check \"**/*.{ts,tsx,js,json,md}\"",
    "format:fix": "prettier --write \"**/*.{ts,tsx,js,json,md}\""
  },
  "keywords": [
    "Zentry",
    "identity",
    "auth",
    "idp",
    "multi-tenant"
  ],
  "author": "Kavinda Rathnayake",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@11.0.9",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.1",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1"
  }
}
